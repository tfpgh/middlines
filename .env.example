# InfluxDB 3 Core — operator token used for all API requests and dashboard login.
# Generate a strong random value, e.g.: openssl rand -hex 32
INFLUXDB3_AUTH_TOKEN=replace-with-a-strong-secret-token

# InfluxDB 3 Explorer UI — secret key for session management.
# Generate a strong random value, e.g.: openssl rand -hex 32
INFLUXDB3_UI_SESSION_SECRET=replace-with-a-strong-secret-key
